generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model DetallePedido {
  Id             Int        @id(map: "PK__DetalleP__3214EC07F2DFB81F") @default(autoincrement())
  PedidoId       Int
  ProductoId     Int
  CantidadLibras Decimal    @db.Decimal(10, 2)
  PrecioUnitario Decimal    @db.Decimal(10, 2)
  Subtotal       Decimal    @db.Decimal(12, 2)
  Pedido         Pedidos    @relation(fields: [PedidoId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Detalle_Pedido")
  Producto       Productos  @relation(fields: [ProductoId], references: [Id], onUpdate: NoAction, map: "FK_Detalle_Producto")
}

model ImagenesProducto {
  Id          Int        @id(map: "PK__Imagenes__3214EC07B2518B9B") @default(autoincrement())
  ProductoId  Int
  UrlImagen   String     @db.VarChar(500)
  EsPrincipal Boolean?   @default(false, map: "DF__ImagenesP__EsPri__4316F928")
  FechaSubida DateTime?  @default(now(), map: "DF__ImagenesP__Fecha__440B1D61") @db.DateTime
  Producto    Productos  @relation(fields: [ProductoId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Imagenes_Productos")
}

model Pagos {
  Id         Int       @id(map: "PK__Pagos__3214EC077C2998F4") @default(autoincrement())
  PedidoId   Int       @unique(map: "UQ__Pagos__09BA14314458DE21")
  MetodoPago String    @db.VarChar(50)
  Estado     String    @db.VarChar(50)
  FechaPago  DateTime? @db.DateTime
  Pedido     Pedidos   @relation(fields: [PedidoId], references: [Id], onDelete: Cascade, onUpdate: NoAction, map: "FK_Pagos_Pedidos")
}

model Pedidos {
  Id            Int              @id(map: "PK__Pedidos__3214EC07B3B69580") @default(autoincrement())
  CompradorId   Int
  FechaPedido   DateTime?        @default(now(), map: "DF__Pedidos__FechaPe__47DBAE45") @db.DateTime
  Estado        String?          @default("Pendiente", map: "DF__Pedidos__Estado__48CFD27E") @db.VarChar(50)
  Total         Decimal          @db.Decimal(12, 2)
  Detalles      DetallePedido[]
  Pago          Pagos?
  Usuario       Usuarios         @relation(fields: [CompradorId], references: [Id], onUpdate: NoAction, map: "FK_Pedidos_Usuarios")
}

model Productos {
  Id               Int                @id(map: "PK__Producto__3214EC07DEAEC916") @default(autoincrement())
  Nombre           String             @db.VarChar(150)
  Descripcion      String?            @db.Text
  Categoria        String             @db.VarChar(50)
  PrecioPorLibra   Decimal            @db.Decimal(10, 2)
  PrecioOriginal   Decimal?           @db.Decimal(10, 2)
  StockLibras      Decimal            @db.Decimal(10, 2)
  VendedorId       Int
  FechaPublicacion DateTime?          @default(now(), map: "DF__Productos__Fecha__3F466844") @db.DateTime
  Detalles         DetallePedido[]
  Imagenes         ImagenesProducto[]
  Usuario          Usuarios           @relation(fields: [VendedorId], references: [Id], onUpdate: NoAction, map: "FK_Productos_Usuarios")
}

model Roles {
  Id       Int        @id(map: "PK__Roles__3214EC07758F4AD1") @default(autoincrement())
  Nombre   String     @unique(map: "UQ__Roles__75E3EFCF176E5DCF") @db.VarChar(50)
  Usuarios Usuarios[]
}

model Usuarios {
  Id            Int         @id(map: "PK__Usuarios__3214EC0755505276") @default(autoincrement())
  Nombre        String      @db.VarChar(100)
  Email         String      @unique(map: "UQ__Usuarios__A9D105348273CCB6") @db.VarChar(100)
  PasswordHash  String      @db.VarChar(255)
  RolId         Int
  FotoUrl       String?     @db.VarChar(500)
  FechaRegistro DateTime?   @default(now(), map: "DF__Usuarios__FechaR__3B75D760") @db.DateTime
  Pedidos       Pedidos[]
  Productos     Productos[]
  Rol           Roles       @relation(fields: [RolId], references: [Id], onUpdate: NoAction, map: "FK_Usuarios_Roles")
  CodigosRecuperacion CodigoRecuperacion[]
}

// ── NUEVA TABLA ──────────────────────────────────────────────────────────────
model CodigoRecuperacion {
  Id        Int      @id @default(autoincrement())
  UsuarioId Int
  Codigo    String   @db.VarChar(6)
  Expira    DateTime @db.DateTime
  Usado     Boolean  @default(false)
  Usuario   Usuarios @relation(fields: [UsuarioId], references: [Id], onDelete: Cascade, onUpdate: NoAction)
}

model Sysdiagrams {
  name         String @db.NVarChar(128)
  principal_id Int
  diagram_id   Int    @id(map: "PK__sysdiagr__C2B05B61631EF481") @default(autoincrement())
  version      Int?
  definition   Bytes?
  @@unique([principal_id, name], map: "UK_principal_name")
}