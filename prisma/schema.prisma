// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


// Configuración del generador y la base de datos
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// 1. Entidad Producto
// 1. Entidad Producto
model Producto {
  cod_prod       Int            @id @default(autoincrement())
  descripcion    String
  precio_libra   Float
  fecha_registro DateTime @default(now())
  fecha_cosecha  DateTime?
  detalles       DetalleVenta[]
}

// 2. Entidad Venta (Cabecera)
model Venta {
  id_venta      Int            @id @default(autoincrement())
  documento     String
  fecha_venta   DateTime       @default(now())
  total_general Float          @default(0)
  detalles      DetalleVenta[]
}

// 3. Entidad DetalleVenta
model DetalleVenta {
  id_detalle_venta Int      @id @default(autoincrement())
  cantidad         Float
  precio_libra     Float
  subtotal         Float
  fecha_registro   DateTime @default(now())
  fecha_cosecha    DateTime?

  // Relaciones: usa nombres consistentes y en minúsculas
  venta            Venta    @relation(fields: [venta_id], references: [id_venta], onDelete: Cascade)
  venta_id         Int

  producto         Producto @relation(fields: [productoId], references: [cod_prod], onDelete: Cascade)
  productoId       Int
}