generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Producto {
  cod_prod       Int            @id @default(autoincrement())
  descripcion    String         @db.NVarChar(255)
  precio_libra   Decimal        @db.Decimal(10,2)
  fecha_registro DateTime       @default(now())
  fecha_cosecha  DateTime?

  detalles       DetalleVenta[]
}

model Venta {
  id_venta      Int            @id @default(autoincrement())
  documento     String         @db.NVarChar(100)
  fecha_venta   DateTime       @default(now())
  total_general Decimal        @default(0) @db.Decimal(12,2)

  detalles      DetalleVenta[]
}

model DetalleVenta {
  id_detalle_venta Int      @id @default(autoincrement())
  cantidad         Decimal  @db.Decimal(10,2)
  precio_libra     Decimal  @db.Decimal(10,2)
  subtotal         Decimal  @db.Decimal(12,2)
  fecha_registro   DateTime @default(now())
  fecha_cosecha    DateTime?

  venta            Venta    @relation(fields: [venta_id], references: [id_venta], onDelete: Cascade)
  venta_id         Int

  producto         Producto @relation(fields: [producto_id], references: [cod_prod], onDelete: Cascade)
  producto_id      Int

  @@index([venta_id])
  @@index([producto_id])
}